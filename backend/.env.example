# ─────────────────────────────────────────────────────────────────
#  JanMitra Backend – Environment Variables
#  Copy this file to .env and fill in real values.
#  Never commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────

# Flask / JWT
SECRET_KEY=your-super-secret-key-minimum-32-characters-long
FLASK_ENV=development          # development | production

# Database (SQLite default; swap for PostgreSQL in production)
DATABASE_URL=sqlite:///data/janmitra.db

# AI / News
GROQ_API_KEY=your_groq_api_key_here
NEWS_API_KEY=your_news_api_key_here

# Twilio (WhatsApp alerts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Cloudinary (Photo Upload) ────────────────────────────────────
# 1. Create a free account at https://cloudinary.com/
# 2. Go to Dashboard → copy Cloud Name, API Key, API Secret
# 3. Images are uploaded to the  janmitra/reports/  folder
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Max image upload size in MB (default: 5)
MAX_UPLOAD_SIZE_MB=5
